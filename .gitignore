# Dependencies
node_modules/
/.pnp
.pnp.js
package-lock.json
yarn.lock

# Rust / Cargo
target/
Cargo.lock
**/*.rs.bk
*.rlib

# Noir
circuits/target/
circuits/target-wasm/
proof_cache/

# Frontend build & cache
/build
/dist
/.svelte-kit
/package
*.local
/frontend/.next
/frontend/.nuxt
/frontend/dist
/frontend/build
/frontend/.cache

# Environment & Secrets
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
.env.test.local

# Private keys / Credentials (NEVER commit these!)
*.pem
*.key
*.p8
*.p12
*.pfx
secret_*
private_*
credentials.json
.aws
.ssh

# IDE & Editor
.vscode/
.vscode-test/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.vim/
.emacs.d/
.netrwhist
Session.vim
.envrc

# IDE Generated
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Logs & Output
logs/
*.log
npm-debug.log*
npm-error.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
pnpm-debug.log
npm-debug.log
debug.log

# Testing
.nyc_output/
coverage/
*.lcov
.mocha/
.test-cache/
test-results/
junit.xml

# macOS
.DS_Store
.AppleDouble
.LSOverride
*.swp
.git-credentials
.github-token

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.Trash-*

# Temporary & Cache files
*.tmp
*.temp
/tmp
.cache/
dist/
build/
.turbo/
.eslintcache
.prettier-ignore

# Soroban / Stellar specific
.soroban/
stellar-asset/
.soroban-cache/
contract-id.txt
wasm-artifacts/

# Noir specific
*.r1cs
*.json.r1cs
noir.toml.bak
nargo.bak
witness/
*.witness

# WASM build artifacts
*.wasm
*.wasm.js
*.wasm.d.ts

# Python / Jupyter (if used for scripts)
__pycache__/
*.pyc
*.pyo
*.egg-info/
.ipynb_checkpoints/
*.ipynb

# Generated files (don't commit these)
contracts/*/src/gen/
frontend/src/generated/
docs/generated/

# Backup files
*.bak
*.backup
*~.bak

# OS-specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Misc
.vscode-settings.json
*.swp
.prettierignore.bak

# ============================================================================
# GitHub Actions
# ============================================================================
# Local runner files
.github/workflows/local/
.act/

# ============================================================================
